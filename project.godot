; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Floppy Warriors"
run/main_scene="uid://m3mdfmp7nyrx"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/bg_color=Color(0.0924416, 0.147392, 0.187741, 1)
config/icon="uid://dgjx66abfarre"

[autoload]

WindowManager="*res://game/scripts/autoloads/window_manager.gd"
CommonGlobals="*res://game/scripts/autoloads/common_globals.gd"
STransitions="*res://addons/my-ecosystem-template/transitions/screen_transitions.tscn"
UiAudioM="*res://addons/my-ecosystem-template/managers/audio/ui_audio_manager.gd"
AudioM="*res://addons/my-ecosystem-template/managers/audio/autoload_audio_manager.gd"
PauseMenu="*res://addons/my-ecosystem-template/pause-menu/pause_menu_layer.tscn"
A="*res://game/scenes/autoloads/autoload.tscn"
SettingsApplier="*uid://b5jtf7dbnupqj"
SettingsManager="*uid://wfehnu87uuxk"
DebugShortcutsManager="*res://addons/my-ecosystem-template/managers/debug_shortcuts_manager.gd"
LayerNames="*uid://dpotfesii40yn"

[display]

window/size/viewport_width=1200
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/handheld/orientation=4

[editor_plugins]

enabled=PackedStringArray("res://addons/basic_settings_menu/plugin.cfg", "res://addons/layer_names/plugin.cfg")

[global_group]

Player=""

[gui]

theme/default_font_antialiasing=2
theme/default_font_multichannel_signed_distance_field=true
theme/custom="uid://c7x5y6w103a4b"
theme/custom_font="uid://dmvkvc82ltc7s"

